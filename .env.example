# Server-only secrets. Never prefix any of these with NEXT_PUBLIC_ —
# that would ship them to the browser.

# Chatbot (src/app/api/chat). When absent, the widget falls back to the
# ported legacy keyword matcher rather than failing — see spec D15.
ANTHROPIC_API_KEY=

# Transactional mail (src/server/mail.ts) — used by both the contact form
# and chatbot lead capture.
RESEND_API_KEY=
CONTACT_TO_EMAIL=business@keiritech.com
CONTACT_FROM_EMAIL=website@keiritech.com

# Public
NEXT_PUBLIC_SITE_URL=https://keiritech.com
